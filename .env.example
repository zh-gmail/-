# AliCloud DashScope API key — used by the Hono backend proxy
# Get your key from: https://bailian.console.aliyun.com/
#
# Option A: Set it here (for local dev)
#   DASHSCOPE_API_KEY="sk-xxx"
#
# Option B: Set as system environment variable (more secure)
#   Windows: setx DASHSCOPE_API_KEY "sk-xxx"
#   macOS/Linux: export DASHSCOPE_API_KEY="sk-xxx"
#
# The server (server/src/index.ts) uses dotenv to load this file.
# Copy this file to .env and fill in your key.
DASHSCOPE_API_KEY="sk-your-key-here"
